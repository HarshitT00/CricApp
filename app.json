{
  "expo": {
    "name": "CricApp",
    "slug": "CricApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d291e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.cricapp",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to mark player attendance.",
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      }
    },
    "android": {
      "package": "com.yourname.cricapp",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0d291e"
      },
      "navigationBar": {
        "style": "dark-content",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-font",
      [
        "expo-system-ui",
        {
          "userInterfaceStyle": "light"
        }
      ],
      "expo-web-browser",
      [
        "expo-navigation-bar",
        {
          "position": "relative",
          "style": "dark"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow CricApp to access your camera to take player photos."
        }
      ]
    ]
  }
}